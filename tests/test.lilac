capture_function: func () cond: @bit8, value: @bit32 {
    cond = 0b1
    value = 0xf
}

gen[T]: obj {

    val: T

    gen2[T2]: obj {
        t: T
        t2: T2
    }

    funct: func () result: @bit8 {
        result = 0x2
    }
}

object: obj {

    value: gen[@bit8]

    @init: func (self, value: @bit8) nothing {
        self.value = value
    }

    // This is an Object

    addOne: func (self) nothing {
        self.value = @iadd(self.value, 0b1)
    } 

    @on_copy: func (self) nothing {
        self.value = @iadd(self.value, 0b1)
    }

    @add: func (lhs: object, rhs: object) result: object {
        result = @iadd(lhs, rhs)
    }

    @conversion: func (from: @number) to: object {
        to = object(@to_int32(from))
    }
}

Enum: enum {
    One
    Two
}

AddOneAble: interface {

    addOne: func (self) nothing
}

private {

    Enum2: enum {
        One
        Two
    }
}